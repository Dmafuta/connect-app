# ── Required environment variables ────────────────────────────────────────────
# Copy to .env (local) or set in your VPS environment / systemd service.
# Generate JWT_SECRET with: openssl rand -base64 48

# Database
DB_URL=jdbc:postgresql://localhost:5432/ispconnect
DB_USERNAME=postgres
DB_PASSWORD=
DDL_AUTO=update   # use 'validate' once schema is stable in production

# JWT
JWT_SECRET=       # openssl rand -base64 48
JWT_EXPIRATION=86400000

# Email (cPanel / SMTP)
MAIL_HOST=server87.web-hosting.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# App
APP_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Africa's Talking
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=QuantumNet
AT_ENV=production
