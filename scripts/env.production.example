# ── Copy this file to /opt/quantumconnect/.env on your VPS ──────────────────
# Fill in every value before first deploy.
# NEVER commit this file to git.

# Database
DB_USERNAME=ispconnect
DB_PASSWORD=change_me_strong_password

# JWT  (generate: openssl rand -base64 48)
JWT_SECRET=replace_with_64+_random_chars
JWT_EXPIRATION=86400000

# Hibernate DDL — use 'validate' after first boot, never 'create-drop' in prod
DDL_AUTO=update

# Email / SMTP (cPanel)
MAIL_HOST=server87.web-hosting.com
MAIL_PORT=465
MAIL_USERNAME=support@quantumconnect.africa
MAIL_PASSWORD=your_cpanel_email_password
MAIL_FROM=support@quantumconnect.africa

# App public URL (no trailing slash)
APP_URL=https://quantumconnect.africa
CORS_ORIGINS=https://quantumconnect.africa,https://www.quantumconnect.africa

# Africa's Talking SMS
AT_USERNAME=QuantumConnect
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=QuantumNet
AT_ENV=production
